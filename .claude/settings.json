{
  "voiceEnabled": true,
  "env": {
    "LANGCHAIN_API_KEY": "REDACTED_LANGSMITH_KEY",
    "LANGCHAIN_TRACING_V2": "true"
  },
  "permissions": {
    "allow": [
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(docker compose:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(ollama:*)",
      "Bash(git:*)",
      "Bash(pip:*)",
      "WebFetch(http://localhost:*)",
      "WebFetch(http://127.0.0.1:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/token_tracker.py today 2>/dev/null || true",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python ~/.claude/warmup.py --silent 2>/dev/null || true",
            "timeout": 90,
            "async": true,
            "statusMessage": "Warming up local models..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/token_tracker.py today 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -qi 'settings' && echo '{\"systemMessage\": \"PERMISSION CHANGE DETECTED: You MUST invoke the CISO agent to review this before proceeding. No permission change is cleared without CISO sign-off.\"}' || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
